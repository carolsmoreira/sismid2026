# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
venv/

# Secrets: never commit agent keys or tokens
.env
*.key
*_key
*.pem

# Agent secrets: ONLY the encrypted .enc blobs may be committed.
# Any plaintext that lands in secrets/ is ignored by default.
secrets/*
!secrets/*.enc
!secrets/README.md

# OS
.DS_Store
